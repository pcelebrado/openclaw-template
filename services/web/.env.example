# =============================================================================
# OpenClaw Web Service (.env.example)
# Environment Placeholder Contract
# =============================================================================
# Copy to .env.local for local development. In Railway, set these as
# service-level environment variables. NEVER commit real values.
# =============================================================================

# --- MongoDB ---
# Connection string for the internal MongoDB service.
# Railway: use the internal Railway connection string (not public).
MONGODB_URI=mongodb://mongo.railway.internal:27017/openclaw

# --- Internal Core Service ---
# Base URL for the internal Core container (OpenClaw + QMD).
# Railway: use the internal networking URL. Never expose this publicly.
INTERNAL_CORE_BASE_URL=http://core.railway.internal:8080

# --- Service-to-Service Auth ---
# Shared secret token for authenticating web -> core calls.
# Must match the same value configured on the Core service.
# Alternative: use INTERNAL_JWT_SIGNING_KEYS for JWT-based auth.
INTERNAL_SERVICE_TOKEN=changeme-generate-a-strong-random-token
# INTERNAL_JWT_SIGNING_KEYS=[{"kid":"k1","secret":"changeme-jwt-signing-key","active":true}]
# INTERNAL_JWT_SIGNING_KEY=changeme-jwt-signing-key

# --- NextAuth / Auth.js ---
# Required for session encryption. Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-auth-secret
# Public-facing URL of this service (Railway auto-provides RAILWAY_PUBLIC_DOMAIN)
AUTH_URL=https://your-domain.railway.app
# Public URL used by server-rendered links (falls back to localhost in development).
NEXT_PUBLIC_APP_URL=https://your-domain.railway.app

# --- Book Content Configuration ---
# Controls where book content is sourced and where it lives at runtime.
# Controls where book content is sourced and where it lives at runtime.
#
# Source mode: how book content arrives on the server.
# Values: external (manual upload/SFTP), sftp (SFTPGo-managed), git (pulled from repo), volume (Railway volume)
BOOK_SOURCE_MODE=external
# Filesystem path where raw book source files are staged before import.
BOOK_SOURCE_DIR=/data/book-source
# Manifest file that describes available book content for import.
BOOK_IMPORT_MANIFEST=/data/book-source/manifest.json
# MongoDB collection names for canonical book data (must match 03-SPEC_MONGO_SCHEMA.md).
BOOK_CANONICAL_COLLECTION=book_sections
BOOK_TOC_COLLECTION=book_toc
# Import controls: disabled by default, dry-run by default when enabled.
BOOK_IMPORT_ENABLED=false
BOOK_IMPORT_DRY_RUN=true

# --- Optional: App Configuration ---
# APP_BASE_URL=https://your-domain.railway.app
# NODE_ENV=production
