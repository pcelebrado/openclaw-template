# =============================================================================
# OpenClaw Mongo Service (.env.example)
# Environment Placeholder Contract
# =============================================================================
# Set these as service-level variables in Railway.
# NEVER commit real values.
# =============================================================================

REPLICA_SET_NAME=rs0
MONGO_INITDB_ROOT_USERNAME=changeme-admin-user
MONGO_INITDB_ROOT_PASSWORD=changeme-admin-password

# Shared replica-set keyfile material. Must be a strong random string.
# Generate: openssl rand -base64 756 | tr -d '\n'
KEYFILE=changeme-rs-keyfile-material

# Runtime defaults used by init scripts when not explicitly overridden.
MONGO_PORT=27017
MONGO_PRIMARY_HOST=mongo.railway.internal
MONGO_REPLICA_HOST=mongo-replica-1.railway.internal
MONGO_REPLICA2_HOST=mongo-replica-2.railway.internal
