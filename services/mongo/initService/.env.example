# =============================================================================
# OpenClaw Mongo Init Service (3-node) (.env.example)
# =============================================================================
# This service should run once to initialize the replica set, then be deleted.
# Never commit real values.
# =============================================================================

REPLICA_SET_NAME=rs0
MONGO_PORT=27017

# Internal DNS names for Mongo node services.
MONGO_PRIMARY_HOST=mongo.railway.internal
MONGO_REPLICA_HOST=mongo-replica-1.railway.internal
MONGO_REPLICA2_HOST=mongo-replica-2.railway.internal

# Preferred credential variables (can also use MONGOUSERNAME/MONGOPASSWORD).
MONGO_INITDB_ROOT_USERNAME=changeme-admin-user
MONGO_INITDB_ROOT_PASSWORD=changeme-admin-password

# Optional verbose logs for troubleshooting.
# DEBUG=1
