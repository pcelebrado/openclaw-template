# =============================================================================
# OpenClaw SFTPGo Service (.env.example)
# =============================================================================
# Set these in Railway Variables. Do not commit real secrets.
# =============================================================================

# Auto-create first SFTPGo admin on first boot.
SFTPGO_DATA_PROVIDER__CREATE_DEFAULT_ADMIN=true
SFTPGO_DEFAULT_ADMIN_USERNAME=changeme-admin
SFTPGO_DEFAULT_ADMIN_PASSWORD=changeme-admin-password

# Web admin/API and SFTP listeners.
SFTPGO_HTTPD__BINDINGS__0__PORT=8080
SFTPGO_SFTPD__BINDINGS__0__PORT=2022
SFTPGO_SFTPD__BINDINGS__0__ADDRESS=

# Persist SFTPGo data and host keys under Railway volume.
SFTPGO_DATA_ROOT=/data/sftpgo

# Optional hardening examples:
# SFTPGO_COMMON__IDLE_TIMEOUT=5
# SFTPGO_COMMON__DEFENDER__ENABLED=true
