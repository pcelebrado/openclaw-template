# =============================================================================
# OpenClaw Core Service (.env.example)
# Environment Placeholder Contract
# =============================================================================
# In Railway, set these as service-level environment variables.
# NEVER commit real values.
# =============================================================================

# --- Service-to-Service Auth ---
# Shared secret token for authenticating web -> core calls.
# Must match the same value configured on the Web service.
INTERNAL_SERVICE_TOKEN=changeme-generate-a-strong-random-token
# INTERNAL_JWT_SIGNING_KEY=changeme-jwt-signing-key

# --- OpenClaw State (already defined in railway.toml, repeated for reference) ---
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
# Optional explicit config path. Defaults to /data/.openclaw/openclaw.json.
# OPENCLAW_CONFIG_PATH=/data/.openclaw/openclaw.json

# --- Setup Password ---
# Protects /setup and dashboard endpoints. Required for Railway deployment.
SETUP_PASSWORD=changeme-strong-setup-password

# --- Gateway Token ---
# Optional: if not set, the wrapper auto-generates and persists one.
# Set explicitly for deterministic token management across redeploys.
# OPENCLAW_GATEWAY_TOKEN=changeme-gateway-token

# --- Internal Gateway Runtime (optional overrides) ---
# Wrapper process binds to Railway's injected PORT automatically.
# Do not set PORT unless you know what you are doing.
# PORT=3000
INTERNAL_GATEWAY_HOST=127.0.0.1
INTERNAL_GATEWAY_PORT=18789

# --- OpenClaw binary/runtime wiring (optional overrides) ---
OPENCLAW_ENTRY=/openclaw/dist/entry.js
OPENCLAW_NODE=node

# --- Book Content Configuration (Core Side) ---
# Core handles import/indexing jobs triggered by the web service.
# See deploy/BOOK_LOCATION_CONTRACT.md for full contract.
#
# Source mode: how book content arrives. Must agree with web service config.
BOOK_SOURCE_MODE=external
# Filesystem path where raw book source files are staged (on Railway volume).
BOOK_SOURCE_DIR=/data/book-source
# Manifest file listing available book content.
BOOK_IMPORT_MANIFEST=/data/book-source/manifest.json
# MongoDB collection names for canonical book data.
BOOK_CANONICAL_COLLECTION=book_sections
BOOK_TOC_COLLECTION=book_toc
# Import controls.
BOOK_IMPORT_ENABLED=false
BOOK_IMPORT_DRY_RUN=true

# --- NOTE: This service is INTERNAL-ONLY ---
# Railway service exposure must be set to "internal" (no public domain).
# All endpoints require Authorization: Bearer <INTERNAL_SERVICE_TOKEN>.
# The wrapper /healthz and /setup/healthz are exceptions for Railway probes.
